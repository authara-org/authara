# Runtime environment
# Default: dev
# Allowed: dev | prod
APP_ENV=dev

# Log level
# Default:
#   dev  -> debug
#   prod -> info
# LOG_LEVEL=debug

POSTGRESQL_HOST=postgres
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=authara
POSTGRESQL_USERNAME=authara
POSTGRESQL_PASSWORD=authara

# Database schema
# Default: authara
# POSTGRESQL_SCHEMA=authara

# Database timezone
# Default: UTC
POSTGRESQL_TIMEZONE=CET

# Log SQL statements
# Default: false (true recommended in dev only)
POSTGRESQL_LOG_SQL=false

# Externally visible base URL of the application
# MUST NOT include /auth
# Examples:
#   http://localhost:3000
#   https://example.com
PUBLIC_URL=http://localhost:3000

# Trust X-Forwarded-For / X-Real-IP from a proxy.
# Enable only when the proxy strips client-supplied forwarded headers.
# Default: false
AUTHARA_TRUST_PROXY_HEADERS=false

# JWT issuer (iss claim)
AUTHARA_JWT_ISSUER=authara

# Active signing key ID
AUTHARA_JWT_ACTIVE_KEY_ID=key-2026-01

# JWT signing keys
# Format: keyID:base64secret,keyID2:base64secret2
# Generate each value with: openssl rand -base64 32
AUTHARA_JWT_KEYS=key-2026-01:replace-with-base64-32-byte-secret,key-2025-09:replace-with-another-base64-32-byte-secret

# Access token lifetime
# Default: 10 minutes
# AUTHARA_ACCESS_TOKEN_TTL_MINUTES=10

# Absolute session lifetime
# Default: 60 days
# AUTHARA_SESSION_TTL_DAYS=60

# Refresh token lifetime
# Default: 14 days
# AUTHARA_REFRESH_TOKEN_TTL_DAYS=14

# Refresh token rotation policy
#
# Controls how often refresh tokens are rotated.
#
# Supported values:
#
#   "" (unset) | "0" | "disabled" | "off"
#       - Rotation disabled
#       - Refresh token is reused until it expires
#
#   "always"
#       - Rotate refresh token on every use
#
#   <duration>
#       - Minimum interval between rotations
#       - Must be a valid Go duration string
#         (examples: 15m, 1h, 24h)
#
# Default: 24h
#
# AUTHARA_REFRESH_TOKEN_ROTATION_INTERVAL=24h

# Comma-separated list of enabled OAuth providers
# Supported: google (github, microsoft, apple later)
# Default: empty (no OAuth providers enabled)
AUTHARA_OAUTH_PROVIDERS=

# Google OAuth client ID
# Required if AUTHARA_OAUTH_PROVIDERS has 'google'
# AUTHARA_OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ------------------------------------------------------------
# Rate limiting
# ------------------------------------------------------------
#
# These limits protect against brute-force login attempts
# and automated signup abuse.
#
# Limits are applied per:
#   - IP address
#   - Email address
#
# If a limit is exceeded, Authara returns HTTP 429.
#
# NOTE:
# - With AUTHARA_CACHE_PROVIDER=noop, limits are per-instance in memory.
# - With AUTHARA_CACHE_PROVIDER=redis, limits are shared through Redis.
#

# Login rate limits:

# Max login attempts per IP within window
# Default: 5
AUTHARA_RATE_LIMIT_LOGIN_IP_LIMIT=5

# Login IP window (Go duration)
# Default: 1m
# AUTHARA_RATE_LIMIT_LOGIN_IP_WINDOW=1m

# Max login attempts per email within window
# Default: 10
AUTHARA_RATE_LIMIT_LOGIN_EMAIL_LIMIT=10

# Login email window (Go duration)
# Default: 1h
# AUTHARA_RATE_LIMIT_LOGIN_EMAIL_WINDOW=1h


# Signup rate limits:

# Max signup attempts per IP within window
# Default: 3
AUTHARA_RATE_LIMIT_SIGNUP_IP_LIMIT=3

# Signup IP window (Go duration)
# Default: 1h
# AUTHARA_RATE_LIMIT_SIGNUP_IP_WINDOW=1h

# Max signup attempts per email within window
# Default: 3
AUTHARA_RATE_LIMIT_SIGNUP_EMAIL_LIMIT=3

# Signup email window (Go duration)
# Default: 24h
# AUTHARA_RATE_LIMIT_SIGNUP_EMAIL_WINDOW=24h

# Password reset rate limits:

# Max password reset attempts per IP within window
# Default: 5
AUTHARA_RATE_LIMIT_PASSWORD_RESET_IP_LIMIT=5

# Password reset IP window (Go duration)
# Default: 1h
# AUTHARA_RATE_LIMIT_PASSWORD_RESET_IP_WINDOW=1h

# Max password reset attempts per email within window
# Default: 3
AUTHARA_RATE_LIMIT_PASSWORD_RESET_EMAIL_LIMIT=3

# Password reset email window (Go duration)
# Default: 24h
# AUTHARA_RATE_LIMIT_PASSWORD_RESET_EMAIL_WINDOW=24h

# Passkey login rate limits:

# Max passkey login option requests per IP within window
# Default: 30
AUTHARA_RATE_LIMIT_PASSKEY_LOGIN_IP_LIMIT=30

# Passkey login IP window (Go duration)
# Default: 10m
# AUTHARA_RATE_LIMIT_PASSKEY_LOGIN_IP_WINDOW=10m

# Challenge verification rate limits:

# Max challenge verification attempts per IP within window
# Default: 30
AUTHARA_RATE_LIMIT_CHALLENGE_VERIFY_IP_LIMIT=30

# Challenge verification IP window (Go duration)
# Default: 10m
# AUTHARA_RATE_LIMIT_CHALLENGE_VERIFY_IP_WINDOW=10m

# Challenge resend rate limits:

# Max challenge resend attempts per IP within window
# Default: 10
AUTHARA_RATE_LIMIT_CHALLENGE_RESEND_IP_LIMIT=10

# Challenge resend IP window (Go duration)
# Default: 1h
# AUTHARA_RATE_LIMIT_CHALLENGE_RESEND_IP_WINDOW=1h

# ----------------------------
# In-memory limiter safety
# ----------------------------

# Cleanup sweep frequency (number of calls between sweeps)
# Default: 200
# AUTHARA_RATE_LIMIT_CLEANUP_EVERY=200

# Maximum number of stored rate limit keys
# Hard safety valve to prevent memory exhaustion
# Default: 50000
# AUTHARA_RATE_LIMIT_MAX_ENTRIES=50000

# ------------------------------------------------------------
# Webhooks
# ------------------------------------------------------------

# Webhook endpoint URL
# If empty, webhooks are disabled
# Example:
#   https://your-app.com/webhooks/authara
# AUTHARA_WEBHOOK_URL=https://your-app.com/webhooks/authara

# Shared secret used to sign webhook requests
# Must match the secret used by your application to verify signatures
# AUTHARA_WEBHOOK_SECRET=replace-with-at-least-32-random-characters

# Comma-separated list of enabled events
#
# Default: empty → all events enabled
#
# Example:
#   user.created,user.deleted
#
# Supported events:
#   user.created
#   user.deleted
#
# AUTHARA_WEBHOOK_ENABLED_EVENTS=

# HTTP timeout for webhook delivery
#
# Must be a valid Go duration string (e.g. 5s, 2s, 1m)
#
# Default: 5s
# AUTHARA_WEBHOOK_TIMEOUT=5s

# ------------------------------------------------------------
# Database connection pool
# ------------------------------------------------------------
#
# Controls how many concurrent database connections Authara uses.
#
# IMPORTANT:
# - Must be tuned relative to Postgres max_connections
# - Applies per Authara instance
#
# Rule of thumb:
#   max_connections (Postgres) / number_of_instances ≈ MaxOpenConns
#
# Example:
#   Postgres max_connections = 200
#   1 instance → 40–80
#   2 instances → 20–40 each
#

# Maximum number of open connections to the database
#
# Default: 40
#
# Increase for higher throughput, but beware:
# - Too high → DB overload ("too many clients")
# - Too low → request queuing
#
AUTHARA_DB_MAX_OPEN_CONNS=40

# Maximum number of idle connections in the pool
#
# Default: 20
#
# Should be <= MAX_OPEN_CONNS
# Higher = better latency, more memory usage
#
AUTHARA_DB_MAX_IDLE_CONNS=20

# Maximum lifetime of a connection
#
# Ensures connections are periodically recycled
# (important for load balancers, proxies, etc.)
#
# Default: 30m
#
AUTHARA_DB_CONN_MAX_LIFETIME=30m

# Maximum idle time of a connection
#
# Idle connections beyond this time are closed
#
# Default: 5m
#
AUTHARA_DB_CONN_MAX_IDLE_TIME=5m

# ------------------------------------------------------------
# Cache
# ------------------------------------------------------------
#
# Supported:
#   noop  -> no shared cache
#   redis -> Redis-backed cache and shared rate limiter
#
# Default: noop
AUTHARA_CACHE_PROVIDER=noop

# Redis connection settings
# Used when AUTHARA_CACHE_PROVIDER=redis
#
# In docker-compose.dev.yaml, use host "redis".
# Outside Docker, localhost is usually correct.
#
AUTHARA_REDIS_HOST=redis
AUTHARA_REDIS_PORT=6379
# AUTHARA_REDIS_PASSWORD=
AUTHARA_REDIS_DB=0

# ------------------------------------------------------------
# Access Policy
# ------------------------------------------------------------
#
# When enabled, only emails explicitly allowed in the system
# may register and authenticate.
#
# If disabled, all emails are accepted.
#

# Enable email allowlist enforcement
# Default: false
AUTHARA_ACCESS_POLICY_ALLOWLIST_ENABLED=false


# ------------------------------------------------------------
# Challenge / Verification
# ------------------------------------------------------------

# Enable challenge system (email verification, etc.)
# Default: false
AUTHARA_CHALLENGE_ENABLED=true

# Lifetime of a challenge (total window)
# Default: 30m
AUTHARA_CHALLENGE_TTL=30m

# Lifetime of verification code
# MUST be <= CHALLENGE_TTL
# Default: 10m
AUTHARA_CHALLENGE_VERIFICATION_CODE_TTL=10m

# Max wrong attempts before challenge is invalid
# Default: 5
AUTHARA_CHALLENGE_MAX_ATTEMPTS=5

# Max resend attempts
# Default: 3
AUTHARA_CHALLENGE_MAX_RESENDS=3

# Minimum time between resends
# Default: 30s
AUTHARA_CHALLENGE_MIN_RESEND_INTERVAL=30s

# ------------------------------------------------------------
# Email
# ------------------------------------------------------------

# Email provider
# Supported:
#   noop  -> logs emails (dev)
#   smtp  -> real email sending
#
# Default: noop
AUTHARA_EMAIL_PROVIDER=noop

# Sender email address (required for smtp)
# AUTHARA_EMAIL_FROM=noreply@authara.local

# SMTP host (required for smtp)
# AUTHARA_EMAIL_SMTP_HOST=localhost

# SMTP port
# Default: 587
# AUTHARA_EMAIL_SMTP_PORT=587

# SMTP username (optional)
# AUTHARA_EMAIL_SMTP_USERNAME=

# SMTP password (optional)
# AUTHARA_EMAIL_SMTP_PASSWORD=

# Enforce STARTTLS
# Default: true
# AUTHARA_EMAIL_SMTP_TLS=true

# SMTP timeout
# Default: 10s
# AUTHARA_EMAIL_SMTP_TIMEOUT=10s

# ------------------------------------------------------------
# Email Worker
# ------------------------------------------------------------

# Number of concurrent workers
# Default: 2
AUTHARA_EMAIL_WORKER_COUNT=1

# Poll interval when no jobs available
# Default: 2s
AUTHARA_EMAIL_WORKER_POLL_INTERVAL=2s

# Max attempts per email job
# Default: 10
AUTHARA_EMAIL_JOB_MAX_ATTEMPTS=10

# ------------------------------------------------------------
# Email Cleanup
# ------------------------------------------------------------

# Delete sent emails after duration
# Default: 30 days
AUTHARA_EMAIL_CLEANUP_SENT_AFTER=720h

# Delete failed emails after duration
# Default: 90 days
AUTHARA_EMAIL_CLEANUP_FAILED_AFTER=2160h
