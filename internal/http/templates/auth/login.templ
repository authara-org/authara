package auth

import (
	"github.com/authara-org/authara/internal/http/kit/httpctx"
	"github.com/authara-org/authara/internal/http/templates"
	"github.com/authara-org/authara/internal/http/templates/components/button"
	"github.com/authara-org/authara/internal/http/templates/components/csrf"
	"github.com/authara-org/authara/internal/http/templates/components/icons"
	"github.com/authara-org/authara/internal/oauth"
)

templ Login(oauthProviders []oauth.OAuthProvider) {
	@templates.PartialRender() {
		@AuthLayout() {
			@CardHeader()
			@HeaderSection("Welcome Back!", "Enter to get unlimited access.")
			@LoginForm()
			@OAuthProviders("Login", oauthProviders)
			<div class="text-center mt-6">
				<p class="text-grey-800 dark:text-grey-200">
					Don't have an Account?
					<a
						hx-get={ "/auth/signup?return_to=" + httpctx.ReturnToOrDefault(ctx, "/") }
						hx-target="#body"
						hx-swap="innerHTML"
						hx-replace-url="true"
						class="cursor-pointer underline text-blue-800 dark:text-blue-400"
					>
						Create an account
					</a>
				</p>
			</div>
		}
	}
}

templ LoginForm() {
	<form
		x-data
		autocomplete="on"
		hx-post={ "/auth/login?return_to=" + httpctx.ReturnToOrDefault(ctx, "/") }
		hx-target="this"
		hx-swap="outerHTML"
	>
		@csrf.CSRFInput()
		<label for="email" class="pb-4 text-grey-800 dark:text-grey-200">
			<div class="pb-1.5">Email <span class="text-red-600">*</span></div>
		</label>
		<input
			type="email"
			id="email"
			name="email"
			autocomplete="username"
			placeholder="Enter your email address"
			required
			class="text-base sm:text-sm placeholder:text-base sm:placeholder:text-sm border-2 border-grey-100 dark:border-grey-800 bg-white dark:bg-grey-900 text-grey-900 dark:text-grey-100 placeholder:text-grey-400 dark:placeholder:text-grey-500 w-full rounded-xl px-4 py-3 mb-4"
		/>
		<label for="current-password" class="text-grey-800 dark:text-grey-200">
			<div class="pb-1.5">Password <span class="text-red-600">*</span></div>
		</label>
		<div x-data="{ show: false }" class="mb-4 relative">
			<input
				:type="show ? 'text' : 'password'"
				id="current-password"
				name="password"
				autocomplete="current-password"
				placeholder="Enter your password"
				required
				class="w-full pl-4 pr-12 py-3 text-base sm:text-sm placeholder:text-base sm:placeholder:text-sm border-2 border-grey-100 dark:border-grey-800 bg-white dark:bg-grey-900 text-grey-900 dark:text-grey-100 placeholder:text-grey-400 dark:placeholder:text-grey-500 rounded-xl"
			/>
			<button
				type="button"
				@click="show = !show"
				class="absolute cursor-pointer right-0 h-full px-4 text-grey-700 dark:text-grey-300"
			>
				<div class="h-5 w-5 my-auto relative">
					<div class="absolute inset-0 bg-white dark:bg-grey-900">
						@icons.Hide()
					</div>
					<div x-cloak x-show="show" class="absolute inset-0 bg-white dark:bg-grey-900">
						@icons.Show()
					</div>
				</div>
			</button>
		</div>
		<div class="flex justify-between mb-4">
			<label class="flex items-center space-x-1.5 cursor-pointer select-none">
				<input
					type="checkbox"
					name="remember"
					class="peer hidden"
					checked
				/>
				<div class="h-4.5 w-4.5 rounded-md border-2 border-blue-600 flex items-center justify-center peer-checked:bg-blue-600 transition">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 20 20"
						fill="currentColor"
						class="w-4 h-4 text-white peer-checked:block"
					>
						<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 011.414-1.414L8.414 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
					</svg>
				</div>
				<span class="text-blue-800 dark:text-blue-400 text-sm">Remember me</span>
			</label>
			if httpctx.ChallengeEnabledOrDefault(ctx, false) {
				<a
					hx-get={ "/auth/password-reset?return_to=/auth/login?return_to=" + httpctx.ReturnToOrDefault(ctx, "/") }
					hx-target="#body"
					hx-swap="innerHTML"
					hx-replace-url="true"
					class="cursor-pointer text-blue-800 dark:text-blue-400 text-sm"
				>
					Reset Password
				</a>
			}
		</div>
		@button.Button(button.ButtonConfig{
			Label: "Login",
			Icon:  icons.Login(),
		})
	</form>
}
